{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/origin-trace-receipt.schema.json",
  "title": "Origin Trace Receipt",
  "description": "A record for preserving origin, trace, transformation, evidence binding, transformation diff, audit, royalty handoff, human review gate, and downstream protocol handoff information for AI-assisted outputs.",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "receipt_id",
    "created_at",
    "origin",
    "trace",
    "transformation",
    "evidence",
    "transformation_diff",
    "audit",
    "royalty_handoff",
    "human_review_gate",
    "boundary",
    "handoff"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.5.0"
    },
    "record_type": {
      "type": "string",
      "const": "origin_trace_receipt"
    },
    "receipt_id": {
      "type": "string",
      "pattern": "^otr_[A-Za-z0-9._-]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "origin": {
      "type": "object",
      "required": [
        "origin_id",
        "title",
        "origin_type",
        "origin_summary"
      ],
      "additionalProperties": false,
      "properties": {
        "origin_id": {
          "type": "string",
          "pattern": "^origin_[A-Za-z0-9._-]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "origin_type": {
          "type": "string",
          "enum": [
            "idea",
            "prompt",
            "document",
            "code",
            "dataset",
            "workflow",
            "protocol",
            "conversation",
            "other"
          ]
        },
        "origin_summary": {
          "type": "string",
          "minLength": 1
        },
        "creator_reference": {
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "license_policy_id": {
          "type": "string"
        }
      }
    },
    "trace": {
      "type": "object",
      "required": [
        "trace_id",
        "source_interactions"
      ],
      "additionalProperties": false,
      "properties": {
        "trace_id": {
          "type": "string",
          "pattern": "^trace_[A-Za-z0-9._-]+$"
        },
        "source_interactions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "source_id",
              "source_type",
              "role",
              "contribution_weight",
              "interaction_summary"
            ],
            "additionalProperties": false,
            "properties": {
              "source_id": {
                "type": "string",
                "pattern": "^source_[A-Za-z0-9._-]+$"
              },
              "source_type": {
                "type": "string",
                "enum": [
                  "user_prompt",
                  "file",
                  "web_page",
                  "repository",
                  "conversation",
                  "model_output",
                  "manual_note",
                  "other"
                ]
              },
              "reference": {
                "type": "string"
              },
              "role": {
                "type": "string",
                "enum": [
                  "primary",
                  "supporting",
                  "background",
                  "counterexample"
                ]
              },
              "contribution_weight": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "interaction_summary": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "transformation": {
      "type": "object",
      "required": [
        "transformation_type",
        "input_summary",
        "output_summary",
        "preserved_elements",
        "changed_elements"
      ],
      "additionalProperties": false,
      "properties": {
        "transformation_type": {
          "type": "string",
          "enum": [
            "summary",
            "rewrite",
            "specification",
            "derivation",
            "composition",
            "analysis",
            "translation",
            "implementation",
            "other"
          ]
        },
        "input_summary": {
          "type": "string",
          "minLength": 1
        },
        "output_summary": {
          "type": "string",
          "minLength": 1
        },
        "preserved_elements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "changed_elements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "required": [
        "evidence_set_id",
        "binding_strategy",
        "evidence_bindings",
        "evidence_summary"
      ],
      "additionalProperties": false,
      "properties": {
        "evidence_set_id": {
          "type": "string",
          "pattern": "^evidence_[A-Za-z0-9._-]+$"
        },
        "binding_strategy": {
          "type": "string",
          "enum": [
            "self_declared",
            "trace_linked",
            "hash_bound",
            "commit_bound",
            "externally_verified",
            "mixed"
          ]
        },
        "evidence_bindings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "binding_id",
              "target_layer",
              "evidence_type",
              "reference_type",
              "reference",
              "verification_status",
              "confidence",
              "evidence_summary"
            ],
            "additionalProperties": false,
            "properties": {
              "binding_id": {
                "type": "string",
                "pattern": "^binding_[A-Za-z0-9._-]+$"
              },
              "target_layer": {
                "type": "string",
                "enum": [
                  "origin",
                  "trace",
                  "transformation",
                  "evidence",
                  "transformation_diff",
                  "audit",
                  "royalty_hook",
                  "royalty_handoff",
                  "human_review_gate",
                  "boundary",
                  "handoff",
                  "validation",
                  "whole_receipt"
                ]
              },
              "evidence_type": {
                "type": "string",
                "enum": [
                  "conversation_excerpt",
                  "file_reference",
                  "repository_commit",
                  "repository_url",
                  "web_url",
                  "document_hash",
                  "model_output",
                  "manual_attestation",
                  "external_receipt",
                  "timestamp",
                  "signature",
                  "other"
                ]
              },
              "reference_type": {
                "type": "string",
                "enum": [
                  "url",
                  "commit_hash",
                  "file_path",
                  "hash",
                  "receipt_id",
                  "text_excerpt",
                  "local_reference",
                  "external_id",
                  "other"
                ]
              },
              "reference": {
                "type": "string",
                "minLength": 1
              },
              "hash": {
                "type": "object",
                "required": [
                  "algorithm",
                  "value"
                ],
                "additionalProperties": false,
                "properties": {
                  "algorithm": {
                    "type": "string",
                    "enum": [
                      "sha256",
                      "sha512",
                      "blake3",
                      "other"
                    ]
                  },
                  "value": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "captured_at": {
                "type": "string",
                "format": "date-time"
              },
              "verification_status": {
                "type": "string",
                "enum": [
                  "unverified",
                  "self_attested",
                  "trace_supported",
                  "hash_verified",
                  "externally_verified",
                  "rejected"
                ]
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "immutable": {
                "type": "boolean"
              },
              "redaction_status": {
                "type": "string",
                "enum": [
                  "none",
                  "partial",
                  "full",
                  "unknown"
                ]
              },
              "privacy_notes": {
                "type": "string"
              },
              "evidence_summary": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "cross_checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "check_id",
              "checked_against",
              "check_result"
            ],
            "additionalProperties": false,
            "properties": {
              "check_id": {
                "type": "string",
                "pattern": "^check_[A-Za-z0-9._-]+$"
              },
              "checked_against": {
                "type": "string",
                "minLength": 1
              },
              "check_result": {
                "type": "string",
                "enum": [
                  "consistent",
                  "partial_match",
                  "conflict",
                  "unknown"
                ]
              },
              "check_notes": {
                "type": "string"
              }
            }
          }
        },
        "evidence_summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "transformation_diff": {
      "type": "object",
      "required": [
        "diff_id",
        "diff_scope",
        "input_references",
        "output_references",
        "diff_items",
        "preservation_score",
        "novelty_score",
        "diff_summary"
      ],
      "additionalProperties": false,
      "properties": {
        "diff_id": {
          "type": "string",
          "pattern": "^diff_[A-Za-z0-9._-]+$"
        },
        "diff_scope": {
          "type": "string",
          "enum": [
            "conceptual",
            "textual",
            "structural",
            "schema",
            "code",
            "workflow",
            "mixed"
          ]
        },
        "input_references": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "output_references": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "diff_items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "element_id",
              "diff_type",
              "source_element",
              "output_element",
              "impact_level",
              "rationale"
            ],
            "additionalProperties": false,
            "properties": {
              "element_id": {
                "type": "string",
                "pattern": "^element_[A-Za-z0-9._-]+$"
              },
              "diff_type": {
                "type": "string",
                "enum": [
                  "preserved",
                  "added",
                  "removed",
                  "modified",
                  "merged",
                  "split",
                  "reordered",
                  "abstracted",
                  "formalized",
                  "other"
                ]
              },
              "source_element": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "output_element": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "impact_level": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high",
                  "critical"
                ]
              },
              "semantic_distance": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "evidence_binding_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^binding_[A-Za-z0-9._-]+$"
                }
              },
              "review_flags": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "requires_human_review",
                    "possible_overwrite",
                    "possible_derivation",
                    "origin_preserved",
                    "high_novelty",
                    "low_traceability",
                    "other"
                  ]
                }
              },
              "rationale": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "preservation_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "novelty_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "diff_summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "audit": {
      "type": "object",
      "required": [
        "synchronization_risk",
        "originality_assessment",
        "evidence_level",
        "evidence_bound",
        "transformation_diff_bound",
        "royalty_handoff_ready",
        "human_review_required",
        "human_review_gate_status"
      ],
      "additionalProperties": false,
      "properties": {
        "synchronization_risk": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "unknown"
          ]
        },
        "originality_assessment": {
          "type": "string",
          "enum": [
            "original",
            "derivative",
            "mixed",
            "uncertain"
          ]
        },
        "evidence_level": {
          "type": "string",
          "enum": [
            "none",
            "self_declared",
            "trace_supported",
            "evidence_bound",
            "externally_verified"
          ]
        },
        "evidence_bound": {
          "type": "boolean"
        },
        "transformation_diff_bound": {
          "type": "boolean"
        },
        "royalty_handoff_ready": {
          "type": "boolean"
        },
        "human_review_required": {
          "type": "boolean"
        },
        "human_review_gate_status": {
          "type": "string",
          "enum": [
            "not_required",
            "required",
            "pending",
            "passed",
            "rejected",
            "blocked"
          ]
        },
        "audit_notes": {
          "type": "string"
        }
      }
    },
    "royalty_hook": {
      "type": "object",
      "required": [
        "enabled",
        "allocation"
      ],
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "policy_id": {
          "type": "string"
        },
        "allocation": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "recipient",
              "role",
              "share_percent"
            ],
            "additionalProperties": false,
            "properties": {
              "recipient": {
                "type": "string"
              },
              "role": {
                "type": "string",
                "enum": [
                  "originator",
                  "contributor",
                  "maintainer",
                  "fund",
                  "other"
                ]
              },
              "share_percent": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              }
            }
          }
        }
      }
    },
    "royalty_handoff": {
      "type": "object",
      "required": [
        "handoff_id",
        "handoff_status",
        "handoff_targets",
        "allocation_basis",
        "license_handoff",
        "review_requirements",
        "settlement_intent",
        "handoff_summary"
      ],
      "additionalProperties": false,
      "properties": {
        "handoff_id": {
          "type": "string",
          "pattern": "^royalty_handoff_[A-Za-z0-9._-]+$"
        },
        "handoff_status": {
          "type": "string",
          "enum": [
            "draft",
            "ready_for_review",
            "ready_for_registration",
            "registered",
            "blocked",
            "not_applicable"
          ]
        },
        "handoff_targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "target_id",
              "target_protocol",
              "target_purpose",
              "required_inputs",
              "missing_inputs",
              "handoff_readiness"
            ],
            "additionalProperties": false,
            "properties": {
              "target_id": {
                "type": "string",
                "pattern": "^target_[A-Za-z0-9._-]+$"
              },
              "target_protocol": {
                "type": "string",
                "enum": [
                  "royalty-os",
                  "compute-access-royalty-os",
                  "origin-structure-market",
                  "origin-license-policy-registry",
                  "okf-royalty-os-bridge",
                  "external_marketplace",
                  "external_registry",
                  "other"
                ]
              },
              "target_reference": {
                "type": "string"
              },
              "target_purpose": {
                "type": "string",
                "enum": [
                  "attribution",
                  "licensing",
                  "royalty_allocation",
                  "market_registration",
                  "compute_access",
                  "dispute_review",
                  "archival",
                  "other"
                ]
              },
              "required_inputs": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "origin",
                    "trace",
                    "evidence",
                    "transformation_diff",
                    "royalty_hook",
                    "license_policy",
                    "human_review",
                    "recipient_identity",
                    "external_contract",
                    "other"
                  ]
                }
              },
              "missing_inputs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "handoff_readiness": {
                "type": "string",
                "enum": [
                  "ready",
                  "partial",
                  "blocked",
                  "not_applicable"
                ]
              },
              "target_notes": {
                "type": "string"
              }
            }
          }
        },
        "allocation_basis": {
          "type": "object",
          "required": [
            "basis_type",
            "source_layers",
            "calculation_method",
            "allocation_notes"
          ],
          "additionalProperties": false,
          "properties": {
            "basis_type": {
              "type": "string",
              "enum": [
                "origin_only",
                "contribution_weight",
                "diff_weighted",
                "evidence_weighted",
                "human_review",
                "external_policy",
                "mixed"
              ]
            },
            "source_layers": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": [
                  "origin",
                  "trace",
                  "evidence",
                  "transformation_diff",
                  "royalty_hook",
                  "boundary",
                  "other"
                ]
              }
            },
            "calculation_method": {
              "type": "string",
              "enum": [
                "none",
                "fixed_split",
                "proportional_weight",
                "manual_review",
                "policy_reference",
                "external_engine",
                "mixed"
              ]
            },
            "allocation_notes": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "license_handoff": {
          "type": "object",
          "required": [
            "license_policy_id",
            "usage_scope",
            "attribution_required",
            "commercial_status",
            "training_status",
            "license_notes"
          ],
          "additionalProperties": false,
          "properties": {
            "license_policy_id": {
              "type": "string"
            },
            "usage_scope": {
              "type": "string",
              "enum": [
                "open",
                "limited",
                "private",
                "internal",
                "custom"
              ]
            },
            "attribution_required": {
              "type": "boolean"
            },
            "commercial_status": {
              "type": "string",
              "enum": [
                "allowed",
                "restricted",
                "prohibited",
                "unknown"
              ]
            },
            "training_status": {
              "type": "string",
              "enum": [
                "allowed",
                "restricted",
                "prohibited",
                "unknown"
              ]
            },
            "license_notes": {
              "type": "string"
            }
          }
        },
        "review_requirements": {
          "type": "object",
          "required": [
            "human_review_required",
            "review_triggers"
          ],
          "additionalProperties": false,
          "properties": {
            "human_review_required": {
              "type": "boolean"
            },
            "reviewer_role": {
              "type": "string",
              "enum": [
                "originator",
                "maintainer",
                "auditor",
                "legal_reviewer",
                "market_operator",
                "other"
              ]
            },
            "review_triggers": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "high_sync_risk",
                  "low_evidence_confidence",
                  "high_derivation",
                  "missing_license_policy",
                  "missing_recipient",
                  "conflicting_claims",
                  "custom_policy",
                  "other"
                ]
              }
            },
            "review_notes": {
              "type": "string"
            }
          }
        },
        "settlement_intent": {
          "type": "object",
          "required": [
            "enabled",
            "execution_mode",
            "settlement_type",
            "settlement_notes"
          ],
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "execution_mode": {
              "type": "string",
              "enum": [
                "record_only",
                "review_required",
                "external_system"
              ]
            },
            "settlement_type": {
              "type": "string",
              "enum": [
                "none",
                "attribution_only",
                "royalty_split",
                "compute_credit",
                "marketplace_listing",
                "external_contract",
                "other"
              ]
            },
            "currency": {
              "type": "string"
            },
            "unit": {
              "type": "string"
            },
            "settlement_notes": {
              "type": "string"
            }
          }
        },
        "handoff_summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "human_review_gate": {
      "type": "object",
      "required": [
        "gate_id",
        "gate_status",
        "review_required",
        "review_triggers",
        "reviewer_roles",
        "blocking_conditions",
        "allowed_after_review",
        "rejected_actions",
        "decision_record",
        "gate_summary"
      ],
      "additionalProperties": false,
      "properties": {
        "gate_id": {
          "type": "string",
          "pattern": "^human_gate_[A-Za-z0-9._-]+$"
        },
        "gate_status": {
          "type": "string",
          "enum": [
            "draft",
            "open",
            "pending_review",
            "passed",
            "rejected",
            "blocked",
            "not_required"
          ]
        },
        "review_required": {
          "type": "boolean"
        },
        "review_triggers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "high_synchronization_risk",
              "medium_synchronization_risk",
              "low_evidence_confidence",
              "missing_origin_reference",
              "missing_license_policy",
              "missing_recipient_identity",
              "conflicting_claims",
              "high_derivation",
              "commercial_use_requested",
              "training_use_requested",
              "external_settlement_requested",
              "market_registration_requested",
              "custom_policy",
              "other"
            ]
          }
        },
        "reviewer_roles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "originator",
              "maintainer",
              "auditor",
              "legal_reviewer",
              "market_operator",
              "royalty_operator",
              "human_gatekeeper",
              "other"
            ]
          }
        },
        "blocking_conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "condition_id",
              "condition_type",
              "severity",
              "blocks_actions",
              "condition_summary"
            ],
            "additionalProperties": false,
            "properties": {
              "condition_id": {
                "type": "string",
                "pattern": "^condition_[A-Za-z0-9._-]+$"
              },
              "condition_type": {
                "type": "string",
                "enum": [
                  "high_sync_risk",
                  "low_evidence_confidence",
                  "missing_origin_reference",
                  "missing_license_policy",
                  "missing_recipient_identity",
                  "conflicting_claims",
                  "high_derivation",
                  "commercial_use",
                  "training_use",
                  "external_settlement",
                  "market_registration",
                  "custom_policy",
                  "other"
                ]
              },
              "severity": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high",
                  "critical"
                ]
              },
              "blocks_actions": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "market_registration",
                    "license_publication",
                    "commercial_use",
                    "training_use",
                    "royalty_execution",
                    "external_settlement",
                    "public_claim",
                    "agent_auto_handoff",
                    "other"
                  ]
                }
              },
              "condition_summary": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "allowed_after_review": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "archive_only",
              "internal_use",
              "attribution_publication",
              "license_publication",
              "market_registration",
              "royalty_handoff",
              "external_settlement",
              "agent_auto_handoff",
              "other"
            ]
          }
        },
        "rejected_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "market_registration",
              "license_publication",
              "commercial_use",
              "training_use",
              "royalty_execution",
              "external_settlement",
              "public_origin_claim",
              "agent_auto_handoff",
              "other"
            ]
          }
        },
        "decision_record": {
          "type": "object",
          "required": [
            "decision_status",
            "decision_authority",
            "decision_notes"
          ],
          "additionalProperties": false,
          "properties": {
            "decision_status": {
              "type": "string",
              "enum": [
                "not_started",
                "pending",
                "approved",
                "approved_with_conditions",
                "rejected",
                "blocked"
              ]
            },
            "decision_authority": {
              "type": "string",
              "enum": [
                "none",
                "originator",
                "maintainer",
                "auditor",
                "legal_reviewer",
                "market_operator",
                "royalty_operator",
                "multi_party_review",
                "other"
              ]
            },
            "reviewed_at": {
              "type": "string",
              "format": "date-time"
            },
            "decision_notes": {
              "type": "string"
            }
          }
        },
        "gate_summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "boundary": {
      "type": "object",
      "required": [
        "usage_policy",
        "prohibited_uses",
        "consent_notes"
      ],
      "additionalProperties": false,
      "properties": {
        "usage_policy": {
          "type": "string",
          "enum": [
            "open",
            "attribution_required",
            "commercial_allowed",
            "commercial_restricted",
            "no_training",
            "custom"
          ]
        },
        "prohibited_uses": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "consent_notes": {
          "type": "string"
        }
      }
    },
    "handoff": {
      "type": "object",
      "required": [
        "next_protocols",
        "related_records",
        "handoff_notes"
      ],
      "additionalProperties": false,
      "properties": {
        "next_protocols": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "ai-search-trace-receipt-standard",
              "synchronization-audit-protocol",
              "origin-structure-market",
              "origin-license-policy-registry",
              "compute-access-royalty-os",
              "kazene-memory-breathing-protocol",
              "trace-relay-protocol",
              "multi-wing-orchestration-generator",
              "other"
            ]
          }
        },
        "related_records": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "handoff_notes": {
          "type": "string"
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "validation_status": {
          "type": "string",
          "enum": [
            "draft",
            "validated",
            "rejected"
          ]
        },
        "receipt_hash": {
          "type": "string"
        }
      }
    }
  }
}
